# Configurazione Database
# Per SQLite locale (default): sqlite:///./iceberg_pm.db
# Per PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./iceberg_pm.db

# Sicurezza
# Cambia questa chiave con una stringa casuale lunga in produzione!
SECRET_KEY=cambiami-con-una-chiave-segreta-molto-lunga-e-casuale

# Opzionale: minuti di validità del token (default 480 = 8 ore)
# ACCESS_TOKEN_EXPIRE_MINUTES=480
